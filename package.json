{
  "name": "serenity",
  "private": true,
  "version": "0.0.0",
  "workspaces": ["frontend"],
  "scripts": {
    "dev": "bun --cwd frontend dev",
    "build": "bun --cwd frontend build",
    "lint": "bun --cwd frontend lint",
    "type-check": "bun --cwd frontend type-check",
    "dev:backend": "cd backend && uv run python manage.py runserver 0.0.0.0:8000",
    "dev:all": "powershell -NoProfile -Command \"Start-Process -NoNewWindow bun -ArgumentList 'run','dev:backend'; bun run dev\""
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "overrides": {
    "undici": "7.28.0",
    "form-data": "4.0.6",
    "rollup": "4.62.2",
    "flatted": "3.4.2",
    "@babel/core": "7.29.7",
    "js-yaml": "4.3.0",
    "picomatch": "4.0.5",
    "brace-expansion": "1.1.15",
    "minimatch": "3.1.5",
    "ajv": "6.15.0",
    "vite": "8.1.3"
  }
}
